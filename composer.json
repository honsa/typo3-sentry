{
	"name": "honsa/typo3-sentry",
	"description": "Sentry",
	"type": "typo3-cms-extension",
	"license": "MIT",
	"require": {
		"php": ">=8.2",
		"typo3/cms-core": "^13.4",
		"sentry/sentry": "^4.3"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.5",
		"typo3/testing-framework": "^9.2",
		"typo3/coding-standards": "^0.8.0",
		"friendsoftypo3/phpstan-typo3": "^0.9.0",
		"phpstan/phpstan": "^1.2.0",
		"friendsofphp/php-cs-fixer": "^3.75"
	},
	"autoload": {
		"psr-4": {
			"Honsa\\Sentry\\": "Classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Honsa\\Sentry\\Tests\\": "Tests/"
		}
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "sentry_logger"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"suggest": {
		"helhum/typo3-console": "For CLI clearing and diagnostics"
	},
	"scripts": {
		"test": "./run-tests.sh",
		"test:unit": "@test",
		"phpstan": ".Build/bin/phpstan analyse --configuration=phpstan.neon Classes",
		"analyze": "@phpstan",
		"cs:lint": ".Build/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose Classes Tests",
		"cs:fix": ".Build/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose Classes Tests"
	},
	"config": {
		"allow-plugins": {
			"typo3/cms-composer-installers": true,
			"typo3/class-alias-loader": true
		},
		"bin-dir": ".Build/bin",
		"vendor-dir": ".Build/vendor"
	}
}
